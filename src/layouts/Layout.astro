---
// Importamos el CSS global de Tailwind
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

// Dejamos la descripción por defecto con las keywords principales empotradas de forma natural
const {
  title,
  description = "Muebles Naiv: Fabricación artesanal de muebles a medida en La Plata. Especialistas en cocinas, placares, vestidores y amoblamientos de diseño en  con la mejor calidad."
} = Astro.props;

const whatsappLink = "https://wa.me/5492216379788?text=Hola%20Muebles%20Naiv!%20Vi%20su%20página%20web%20y%20me%20gustaría%20pedir%20un%20presupuesto.";

const canonicalURL = new URL(Astro.url.pathname, "https://mueblesnaiv.com");
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
       
        <title>{title} | Muebles Naiv La Plata</title>
        <meta name="description" content={description}>
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={`${title} | Muebles Naiv La Plata`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="/og-image.jpg" />

        <script type="application/ld+json" is:inline define:vars={{ description }}>
            {
                "@context": "https://schema.org",
                "@type": "FurnitureStore",
                "name": "Muebles Naiv",
                "description": "Fabricación artesanal de muebles a medida en La Plata. Diseños en melamina.",
                "url": "https://mueblesnaiv.com",
                "telephone": "+542214539319",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Calle 61 1276",
                    "addressLocality": "La Plata",
                    "addressRegion": "Buenos Aires",
                    "postalCode": "1900",
                    "addressCountry": "AR"
                },
                "geo": {
                    "@type": "GeoCoordinates",
                    "latitude": -34.9317,
                    "longitude": -57.9482
                },
                "openingHoursSpecification": {
                    "@type": "OpeningHoursSpecification",
                    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                    "opens": "08:30",
                    "closes": "18:00"
                }
            }
        </script>
    </head>
    <body class="bg-white text-gray-800 antialiased pt-20">
        <Header />
        <slot />
        <Footer />
       
        <a
            href={whatsappLink}
            target="_blank"
            class="fixed bottom-8 right-8 z-[100] bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform flex items-center justify-center"
            aria-label="Contactar por WhatsApp"
        >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
        </a>
    </body>
</html>

<style>
    h1 {
        font-family: 'Times New Roman', Times, serif;
    }
</style>