---
import { Instagram, Facebook, Mail, MessageCircle, MapPin } from 'lucide-astro';

const whatsappLink = "https://wa.me/5492216379788?text=Hola%20Muebles%20Naiv!%20Vi%20su%20página%20web%20y%20me%20gustaría%20pedir%20un%20presupuesto.";
const googleLink = "https://www.google.com/maps/place/Muebles+Naiv/@-34.9345257,-57.9541329,15z/data=!4m5!3m4!1s0x0:0x675e0e97849e1d60!8m2!3d-34.9345257!4d-57.9541329";

---

<header class="fixed top-0 w-full z-50 bg-[#2c3c5d]/90 backdrop-blur-sm border-b border-white/10 text-white">
    <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
        <a href="/" class="text-xl font-bold tracking-[0.3em] uppercase hover:text-blue-200 transition">Muebles Naiv</a>

        <nav class="hidden md:flex gap-8 uppercase text-xs tracking-widest font-medium">
            <a href="/" class="hover:text-blue-300 transition">Inicio</a>
            <a href="/proyectos" class="hover:text-blue-300 transition">Proyectos</a>
            <a href="/contacto" class="hover:text-blue-300 transition">Contacto</a>
        </nav>

        <div class="flex items-center gap-5">
            <a href="https://www.instagram.com/naiv_amoblamientos" target="_blank" class="text-white hover:text-blue-300 hover:scale-110 transition flex items-center">
                <Instagram size={20} strokeWidth={1.5} />
            </a>

            <a href={googleLink} target="_blank" class="text-white hover:text-blue-300 hover:scale-110 transition flex items-center">
                <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    viewBox="0 0 24 24" 
                    fill="currentColor" 
                    class="w-[20px] h-[20px]"
                >
                    <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                </svg>
            </a>

            <a href={whatsappLink} target="_blank" class="text-white hover:text-blue-300 hover:scale-110 transition flex items-center">
                <svg 
                xmlns="http://www.w3.org/2000/svg" 
                viewBox="0 0 24 24" 
                fill="currentColor" 
                class="w-[20px] h-[20px]" 
                >
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
            </a>

            <a href="https://es-la.facebook.com/muebles.veafabricar" target="_blank" class="text-white hover:text-blue-300 hover:scale-110 transition flex items-center">
                <Facebook size={20} strokeWidth={1.5} />
            </a>
            
        </div>
    </div>
</header>