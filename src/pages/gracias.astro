---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mensaje Recibido | Muebles Naiv">
    <main class="py-20 text-center">
        <h1 class="text-3xl font-serif text-[#2c3c5d] mb-4">¡Gracias por contactarnos!</h1>
        <p class="text-gray-600 mb-8">Hemos recibido tu mensaje. Te responderemos a la brevedad.</p>
        <a href="/" class="bg-[#2c3c5d] text-white px-6 py-3 rounded-full hover:bg-[#d64747] transition-colors">
            Volver al inicio
        </a>
    </main>
</Layout>